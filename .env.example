# Server Configuration
NODE_ENV=production
PORT=10000
HOST=0.0.0.0
LOG_LEVEL=info
LIGMA_SYNC_PATH=/ligma-sync

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database
DATABASE_PATH=./data/ligma.db

# DigitalOcean AI Configuration
# Required for AI Summary and MCP (AI Explainer / Diagram) features.
# Without these three, the related endpoints return 503.
DO_AI_API_KEY=your-digitalocean-api-key
DO_AI_MODEL=llama3-8b-instruct
DO_AI_ENDPOINT=https://api.digitalocean.com/v2/ai/chat/completions

# MCP (AI Explainer) — optional tuning. Defaults shown.
# Toggle response cache (true | false). When true, identical (room, task)
# requests within MCP_CACHE_TTL_SECONDS skip the LLM call.
MCP_CACHE_ENABLED=true
MCP_CACHE_TTL_SECONDS=300

# Per-user rate limit. After this many requests in a 60s window the user
# receives 429 Too Many Requests with a retry-after header.
MCP_RATE_LIMIT_PER_MINUTE=10

# How many nearby tasks to include as context, and how far away (canvas
# units) "nearby" means.
MCP_MAX_RELATED_TASKS=10
MCP_PROXIMITY_RADIUS=500
