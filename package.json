{
  "name": "ligma",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.2",
  "private": true,
  "description": "LIGMA — real-time collaborative ideation surface (DevDay'26 Hackathon, spec rebuild)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run -ws --if-present --parallel dev",
    "build": "npm run build:server",
    "build:server": "npm run -w @ligma/shared build && npm run -w @ligma/server build",
    "build:web": "npm run -w @ligma/web build",
    "lint": "npm run -ws --if-present lint",
    "seed": "npm run -w @ligma/server seed",
    "server": "npm run -w @ligma/server dev",
    "web": "npm run -w @ligma/web dev",
    "start": "npm run -w @ligma/server start"
  },
  "devDependencies": {
    "@vercel/node": "^3.0.0",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
